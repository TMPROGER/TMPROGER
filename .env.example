TELEGRAM_BOT_TOKEN=your_telegram_bot_token
IMAGE_API_KEY=your_image_api_key
# OpenAI-совместимый endpoint с поддержкой POST /images/generations
IMAGE_API_BASE_URL=https://api.openai.com/v1
# Любая доступная модель на вашем endpoint, например: gpt-image-1
IMAGE_MODEL=gpt-image-1
# Формат результата: PNG, JPEG или WEBP (если поддерживается провайдером)
IMAGE_RESPONSE_FORMAT=png
# Размер изображения по умолчанию, например 1024x1024
IMAGE_SIZE=1024x1024
# Интервал свечей для анализа (интервалы Yahoo), например 5m, 15m, 1h
SIGNAL_INTERVAL=15m
# Диапазон истории рынка, например 1d, 5d, 1mo
SIGNAL_RANGE=5d
